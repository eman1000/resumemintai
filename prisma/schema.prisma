generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String   @id @default(uuid()) @db.Uuid
  email                  String?  @unique
  firebaseUid            String?  @unique @map("firebase_uid")
  stripeCustomerId       String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?  @map("stripe_subscription_id")
  plan                   String   @default("free")
  // Persisted answers to common application screening questions (work
  // authorization, citizenship, salary, notice period, …) so the Apply agent
  // stops re-asking them every application.
  applicantProfile       Json?    @map("applicant_profile")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  resumes       Resume[]
  coverLetters  CoverLetter[]
  subscriptions Subscription[]
  jobResults    JobResult[]
  aiUsage       AiUsage[]
  applications  Application[]

  @@map("users")
}

model Resume {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  title           String   @default("Untitled CV")
  renderer        String   @default("professional")
  data            Json     @default("{}")
  language        String?
  thumbnailUrl    String?  @map("thumbnail_url")
  archived        Boolean  @default(false)
  // If this resume was generated by /api/jobs/tailor-kit, this column holds
  // a snapshot of the job it was tailored for: { source, title, company,
  // location, postedAt? }. Null for organic resumes the user created.
  tailoredForJob  Json?    @map("tailored_for_job")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverLetters CoverLetter[]

  @@index([userId])
  @@map("resumes")
}

model CoverLetter {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  resumeId        String?  @map("resume_id") @db.Uuid
  title           String   @default("Untitled Cover Letter")
  renderer        String   @default("professional")
  data            Json     @default("{}")
  language        String?
  thumbnailUrl    String?  @map("thumbnail_url")
  archived        Boolean  @default(false)
  tailoredForJob  Json?    @map("tailored_for_job")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resumeId])
  @@map("cover_letters")
}

model Subscription {
  id                  String    @id // Stripe subscription id
  userId              String    @map("user_id") @db.Uuid
  status              String
  priceId             String?   @map("price_id")
  currentPeriodEnd    DateTime? @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd   Boolean   @default(false) @map("cancel_at_period_end")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model JobResult {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  requestedRole String   @map("requested_role")
  location      String?
  country       String?
  results       Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("job_results")
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  event       String
  props       Json     @default("{}")
  keymanId    String?  @map("keyman_id")
  uid         String?
  ua          String?
  ip          String?
  ref         String?
  path        String?
  tsClient    DateTime @map("ts_client") @db.Timestamptz
  tsServer    DateTime @default(now()) @map("ts_server") @db.Timestamptz
  dedupeKey   String?  @map("dedupe_key")
  ipCountry   String?  @map("ip_country")
  regionCode  String?  @map("region_code")
  city        String?
  postalCode  String?  @map("postal_code")
  lat         Float?
  lon         Float?
  geoSource   String?  @map("geo_source")
  country     String?

  @@unique([event, dedupeKey])
  @@index([tsServer])
  @@map("events")
}

model Application {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  // ATS family the application went through ("greenhouse", "workable",
  // "ashby", "manual", …). Drives which submitter we use + how we display
  // status. Free-form for forward compatibility.
  ats           String
  // What the user submitted to — frozen so a cache rotation doesn't lose
  // the listing details: { source, title, company, location, postedAt }.
  jobSnapshot   Json     @map("job_snapshot")
  // Lifecycle: 'draft' (preview, not yet submitted) → 'submitted' (POST returned 2xx)
  // → 'applied' (user manually marks themselves applied for non-API hosts) →
  // 'interviewing' | 'offer' | 'rejected' | 'withdrawn'.
  status        String   @default("draft")
  // ATS-side identifier (e.g. Greenhouse "candidate_id") if returned by submit.
  externalRef   String?  @map("external_ref")
  // Optional resume + cover letter rows that were submitted with this app.
  resumeId      String?  @map("resume_id") @db.Uuid
  coverLetterId String?  @map("cover_letter_id") @db.Uuid
  // Free-form user notes (e.g. "rec'd HR ping 22 May").
  notes         String?
  // Server-side response body (for debugging submit failures).
  response      Json?
  submittedAt   DateTime? @map("submitted_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("applications")
}

model AiUsage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  // Feature key, e.g. "tailor-kit" | "cover-letter-tailor" | "ats-optimize"
  // | "section-suggest". Free-form string so we can add features without
  // schema changes; the lib/aiUsage.ts table holds the per-feature limits.
  feature   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
  @@index([createdAt])
  @@map("ai_usage")
}

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String?
  message   String
  keymanId  String?  @map("keyman_id")
  path      String?
  ref       String?
  ua        String?
  ip        String?
  ipCountry String?  @map("ip_country")
  ipRegion  String?  @map("ip_region")
  ipCity    String?  @map("ip_city")
  ipPostal  String?  @map("ip_postal")
  ipLat     Float?   @map("ip_lat")
  ipLon     Float?   @map("ip_lon")
  country   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("contacts")
}
