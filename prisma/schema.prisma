generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String   @id @default(uuid()) @db.Uuid
  email                String?  @unique
  firebaseUid          String?  @unique @map("firebase_uid")
  stripeCustomerId     String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  plan                 String   @default("free")
  // Which side of the marketplace this account primarily acts as:
  // "candidate" (default) | "recruiter". Drives post-login routing and which
  // dashboard/nav we show. Recruiter *features* are gated on an active
  // recruiter subscription, not just this flag.
  userType             String   @default("candidate") @map("user_type")
  // Recruiter company name (shown on job postings). Null for candidates.
  companyName          String?  @map("company_name")
  // Persisted answers to common application screening questions (work
  // authorization, citizenship, salary, notice period, …) so the Apply agent
  // stops re-asking them every application.
  applicantProfile     Json?    @map("applicant_profile")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  resumes         Resume[]
  coverLetters    CoverLetter[]
  subscriptions   Subscription[]
  jobResults      JobResult[]
  aiUsage         AiUsage[]
  applications    Application[]
  jobPostings     JobPosting[]
  jobApplications JobApplication[]
  shortlistRuns   ShortlistRun[]

  @@map("users")
}

model Resume {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  title          String   @default("Untitled CV")
  renderer       String   @default("professional")
  data           Json     @default("{}")
  language       String?
  thumbnailUrl   String?  @map("thumbnail_url")
  archived       Boolean  @default(false)
  // The user's master resume (source of truth). At most one per user; tailoring
  // derives non-destructive copies from it. See lib/masterResume.ts.
  isMaster       Boolean  @default(false) @map("is_master")
  // If this resume was generated by /api/jobs/tailor-kit, this column holds
  // a snapshot of the job it was tailored for: { source, title, company,
  // location, postedAt? }. Null for organic resumes the user created.
  tailoredForJob Json?    @map("tailored_for_job")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverLetters CoverLetter[]

  @@index([userId])
  @@map("resumes")
}

model CoverLetter {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  resumeId       String?  @map("resume_id") @db.Uuid
  title          String   @default("Untitled Cover Letter")
  renderer       String   @default("professional")
  data           Json     @default("{}")
  language       String?
  thumbnailUrl   String?  @map("thumbnail_url")
  archived       Boolean  @default(false)
  tailoredForJob Json?    @map("tailored_for_job")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resumeId])
  @@map("cover_letters")
}

model Subscription {
  id                String    @id // Stripe subscription id
  userId            String    @map("user_id") @db.Uuid
  status            String
  priceId           String?   @map("price_id")
  currentPeriodEnd  DateTime? @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd Boolean   @default(false) @map("cancel_at_period_end")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model JobResult {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  requestedRole String   @map("requested_role")
  location      String?
  country       String?
  results       Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("job_results")
}

model Event {
  id         String   @id @default(uuid()) @db.Uuid
  event      String
  props      Json     @default("{}")
  keymanId   String?  @map("keyman_id")
  uid        String?
  ua         String?
  ip         String?
  ref        String?
  path       String?
  tsClient   DateTime @map("ts_client") @db.Timestamptz
  tsServer   DateTime @default(now()) @map("ts_server") @db.Timestamptz
  dedupeKey  String?  @map("dedupe_key")
  ipCountry  String?  @map("ip_country")
  regionCode String?  @map("region_code")
  city       String?
  postalCode String?  @map("postal_code")
  lat        Float?
  lon        Float?
  geoSource  String?  @map("geo_source")
  country    String?

  @@unique([event, dedupeKey])
  @@index([tsServer])
  @@map("events")
}

model Application {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  // ATS family the application went through ("greenhouse", "workable",
  // "ashby", "manual", …). Drives which submitter we use + how we display
  // status. Free-form for forward compatibility.
  ats           String
  // What the user submitted to — frozen so a cache rotation doesn't lose
  // the listing details: { source, title, company, location, postedAt }.
  jobSnapshot   Json      @map("job_snapshot")
  // Lifecycle: 'draft' (preview, not yet submitted) → 'submitted' (POST returned 2xx)
  // → 'applied' (user manually marks themselves applied for non-API hosts) →
  // 'interviewing' | 'offer' | 'rejected' | 'withdrawn'.
  status        String    @default("draft")
  // ATS-side identifier (e.g. Greenhouse "candidate_id") if returned by submit.
  externalRef   String?   @map("external_ref")
  // Optional resume + cover letter rows that were submitted with this app.
  resumeId      String?   @map("resume_id") @db.Uuid
  coverLetterId String?   @map("cover_letter_id") @db.Uuid
  // Free-form user notes (e.g. "rec'd HR ping 22 May").
  notes         String?
  // Server-side response body (for debugging submit failures).
  response      Json?
  submittedAt   DateTime? @map("submitted_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("applications")
}

model AiUsage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  // Feature key, e.g. "tailor-kit" | "cover-letter-tailor" | "ats-optimize"
  // | "section-suggest". Free-form string so we can add features without
  // schema changes; the lib/aiUsage.ts table holds the per-feature limits.
  feature   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
  @@index([createdAt])
  @@map("ai_usage")
}

// ── Recruiter product ──────────────────────────────────────────────────────

model JobPosting {
  id             String    @id @default(uuid()) @db.Uuid
  recruiterId    String    @map("recruiter_id") @db.Uuid
  // URL-safe public identifier (title slug + short suffix). Drives /careers/[slug].
  slug           String    @unique
  title          String
  company        String
  location       String?
  // full-time | part-time | contract | internship | temporary
  employmentType String?   @map("employment_type")
  remote         Boolean   @default(false)
  // Full job description (plain text / light markdown).
  description    String
  salaryMin      Int?      @map("salary_min")
  salaryMax      Int?      @map("salary_max")
  currency       String?   @default("EUR")
  // draft | open | closed
  status         String    @default("open")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  closedAt       DateTime? @map("closed_at") @db.Timestamptz

  recruiter     User             @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  applications  JobApplication[]
  shortlistRuns ShortlistRun[]

  @@index([status, createdAt])
  @@index([recruiterId, createdAt])
  @@map("job_postings")
}

model JobApplication {
  id             String   @id @default(uuid()) @db.Uuid
  jobPostingId   String   @map("job_posting_id") @db.Uuid
  applicantId    String   @map("applicant_id") @db.Uuid
  resumeId       String?  @map("resume_id") @db.Uuid
  coverLetterId  String?  @map("cover_letter_id") @db.Uuid
  // Frozen plaintext of the chosen resume at apply time, so AI shortlisting can
  // rank applicants without re-rendering. See lib/shortlist.ts.
  resumeText     String?  @map("resume_text")
  // Contact snapshot frozen at apply time (resume edits later won't change it).
  applicantName  String?  @map("applicant_name")
  applicantEmail String?  @map("applicant_email")
  // Optional short note / cover message from the applicant.
  note           String?
  // submitted | reviewing | shortlisted | rejected | withdrawn
  status         String   @default("submitted")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  jobPosting       JobPosting           @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  applicant        User                 @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  shortlistEntries ShortlistCandidate[]

  // One application per candidate per posting.
  @@unique([jobPostingId, applicantId])
  @@index([jobPostingId, status])
  @@index([applicantId, createdAt])
  @@map("job_applications")
}

model ShortlistRun {
  id           String   @id @default(uuid()) @db.Uuid
  recruiterId  String   @map("recruiter_id") @db.Uuid
  // Null when run from the ad-hoc upload tool (not tied to a board posting).
  jobPostingId String?  @map("job_posting_id") @db.Uuid
  // Human label for the history list (posting title, or "Ad-hoc upload").
  label        String?
  jdText       String   @map("jd_text")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  recruiter  User                 @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  jobPosting JobPosting?          @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  candidates ShortlistCandidate[]

  @@index([recruiterId, createdAt])
  @@map("shortlist_runs")
}

model ShortlistCandidate {
  id            String   @id @default(uuid()) @db.Uuid
  runId         String   @map("run_id") @db.Uuid
  // Links back to the board application when ranking a posting's applicants.
  applicationId String?  @map("application_id") @db.Uuid
  name          String
  score         Int
  verdict       String?
  strengths     Json     @default("[]")
  gaps          Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  run         ShortlistRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  application JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([runId, score])
  @@map("shortlist_candidates")
}

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String?
  message   String
  keymanId  String?  @map("keyman_id")
  path      String?
  ref       String?
  ua        String?
  ip        String?
  ipCountry String?  @map("ip_country")
  ipRegion  String?  @map("ip_region")
  ipCity    String?  @map("ip_city")
  ipPostal  String?  @map("ip_postal")
  ipLat     Float?   @map("ip_lat")
  ipLon     Float?   @map("ip_lon")
  country   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("contacts")
}
