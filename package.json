{
  "name": "ai-resume-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d db",
    "db:migrate": "DATABASE_URL=postgresql://resumemint:resumemint@localhost:5433/resumemint_dev?sslmode=disable DIRECT_URL=postgresql://resumemint:resumemint@localhost:5433/resumemint_dev?sslmode=disable prisma migrate deploy",
    "db:migrate:dev": "DATABASE_URL=postgresql://resumemint:resumemint@localhost:5433/resumemint_dev?sslmode=disable DIRECT_URL=postgresql://resumemint:resumemint@localhost:5433/resumemint_dev?sslmode=disable prisma migrate dev",
    "db:studio": "DATABASE_URL=postgresql://resumemint:resumemint@localhost:5433/resumemint_dev?sslmode=disable prisma studio",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "capture:previews": "node scripts/capture-template-previews.mjs",
    "build:extension": "node scripts/build-extension-zip.mjs"
  },
